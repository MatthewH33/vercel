# Option A — full URI from Atlas (Connect → Drivers → insert password)
MONGODB_URI=mongodb+srv://USER:PASSWORD@agsvfantacy.aigkcfe.mongodb.net/agsv?retryWrites=true&w=majority&appName=agsvfantacy

# Option B — separate vars (password special chars are encoded for you)
# MONGODB_USER=fantasy
# MONGODB_PASSWORD=your_password_from_atlas
# MONGODB_HOST=agsvfantacy.aigkcfe.mongodb.net
# MONGODB_DB=agsv

# Required in production (Vercel). Generate: openssl rand -hex 32
SESSION_SECRET=replace-with-a-long-random-string
